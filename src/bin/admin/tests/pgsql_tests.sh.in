    assert_eq 0 "${EXIT_CODE}" "${query}. (expected status code %d, returned %d)"
    assert_str_eq 'internal' "${OUTPUT}" "${query}: expected output %s, returned %s"

    query="select name from option_def_data_type where id = 254"
