                                 ('127.0.0.8'::inet - '0.0.0.0'::inet), 1, false)"
    run_statement "sflqCreateFlqPool4" "$sql"
    unset KEA_EXPECTED_EXIT_CODE

    # Start address  larger than end address is invalid
    export KEA_EXPECTED_EXIT_CODE="3"
    sql="select sflqCreateFlqPool4(('127.0.0.8'::inet - '0.0.0.0'::inet),
                                 ('127.0.0.0'::inet - '0.0.0.0'::inet), 1, false)"
    run_statement "sflqCreateFlqPool4" "$sql"
    unset KEA_EXPECTED_EXIT_CODE

    # Let's wipe the whole database
    pgsql_wipe

    test_finish 0
}

# Verifies sflqPickFreeLease4 function
pgsql_sflqPickFreeLease4() {
    test_start "pgsql.pgsql_sflqPickFreeLease4"

    # Let's wipe the whole database
    pgsql_wipe

    # Create the database
    run_command \
        "${kea_admin}" db-init pgsql -u "${db_user}" -p "${db_password}" -n "${db_name}" -d "${db_scripts_dir}"
    assert_eq 0 "${EXIT_CODE}" "cannot initialize the database, expected exit code: %d, actual: %d"

    start_address="('127.0.0.0'::inet - '0.0.0.0'::inet)"
    end_address="('127.0.0.2'::inet - '0.0.0.0'::inet)"
    sql="select sflqCreateFlqPool4($start_address, $end_address, 1::bigint, false)"
    run_statement "sflqCreateFlqPool4" "$sql"

    sql="select ('0.0.0.0'::inet + sflqPickFreeLease4($start_address, $end_address))"
    run_statement "sflqPickFreeLease4.1" "$sql"  "127.0.0.0";
    run_statement "sflqPickFreeLease4.2" "$sql"  "127.0.0.1";
    run_statement "sflqPickFreeLease4.3" "$sql"  "127.0.0.2";

    # Inserting a lease directly. Pick should still see it.
    sql="insert into lease4 (address, subnet_id) values ('127.0.0.1'::inet - '0.0.0.0'::inet, 1)";
    run_statement "insert 127.0.0.1" "$sql"  "";

    # Inserting an active lease directly. Pick should still see it.
    sql="select ('0.0.0.0'::inet + sflqPickFreeLease4($start_address, $end_address))"
    run_statement "sflqPickFreeLease4.4" "$sql"  "127.0.0.0";
    run_statement "sflqPickFreeLease4.5" "$sql"  "127.0.0.1";
    run_statement "sflqPickFreeLease4.6" "$sql"  "127.0.0.2";

    # Updating a lease directly. Pick should still see it.
    sql="update lease4 set state = 2 where address = ('127.0.0.1'::inet - '0.0.0.0'::inet);"
    run_statement "update 127.0.0.1" "$sql"  "";

    sql="select ('0.0.0.0'::inet + sflqPickFreeLease4($start_address, $end_address))"
    run_statement "sflqPickFreeLease4.7" "$sql"  "127.0.0.0";
    run_statement "sflqPickFreeLease4.8" "$sql"  "127.0.0.1";
    run_statement "sflqPickFreeLease4.9" "$sql"  "127.0.0.2";

    # Deleting a lease directly. Pick should still see it.
    sql="delete from lease4"
    run_statement "delete 127.0.0.1" "$sql"  "";

    sql="select ('0.0.0.0'::inet + sflqPickFreeLease4($start_address, $end_address))"
    run_statement "sflqPickFreeLease4.10" "$sql"  "127.0.0.0";
    run_statement "sflqPickFreeLease4.11" "$sql"  "127.0.0.1";
    run_statement "sflqPickFreeLease4.12" "$sql"  "127.0.0.2";

    # Check pools with one address.
    address="('192.0.2.0'::inet - '0.0.0.0'::inet)"
    sql="select sflqCreateFlqPool4(${address}, ${address}, 1::bigint, false)"
    run_statement "sflqCreateFlqPool4.2" "${sql}"
    sql="select ('0.0.0.0'::inet + sflqPickFreeLease4(${address}, ${address}))"
    run_statement "sflqPickFreeLease4.13" "${sql}" "192.0.2.0";
    # Rolling over results in the same address when there is only one.
    run_statement "sflqPickFreeLease4.14" "${sql}" "192.0.2.0";

    # Check picking 255.255.255.255.
    address="('255.255.255.255'::inet - '0.0.0.0'::inet)"
    sql="select sflqCreateFlqPool4(${address}, ${address}, 1::bigint, false)"
    run_statement "sflqCreateFlqPool4.4" "${sql}"
    sql="select ('0.0.0.0'::inet + sflqPickFreeLease4(${address}, ${address}))"
    run_statement "sflqPickFreeLease4.17" "${sql}" "255.255.255.255";
    run_statement "sflqPickFreeLease4.18" "${sql}" "255.255.255.255";

    # Let's wipe the whole database
    pgsql_wipe

    test_finish 0
}

# Verifies SFLQ sflqCreateFlqPool6 function
pgsql_sflqCreateFlqPool6() {
    test_start "pgsql.pgsql_sflqCreateFlqPool6"

    # Let's wipe the whole database
    pgsql_wipe

    # Create the database
    run_command \
        "${kea_admin}" db-init pgsql -u "${db_user}" -p "${db_password}" -n "${db_name}" -d "${db_scripts_dir}"
    assert_eq 0 "${EXIT_CODE}" "cannot initialize the database, expected exit code: %d, actual: %d"

    # Get a future timestamp
    sql="select (CURRENT_TIMESTAMP + make_interval(secs => 3600))"
    run_statement "get expired time stamp" "$sql"
    future="${OUTPUT}"

    # Get an expired timestamp
    sql="select (CURRENT_TIMESTAMP - make_interval(secs => 3600))"
    run_statement "get expired time stamp" "$sql"
    expired="${OUTPUT}"

    # Insert an assigned lease
    sql="insert into lease6 (address, lease_type, subnet_id, valid_lifetime, expire, state) \
            values ('3001::1'::inet, 1, 1, 3600, '$future'::timestamp, 0)";
    run_statement "insert 3001::1" "$sql"  "";

    # Insert a declined lease
    sql="insert into lease6 (address, lease_type, subnet_id, valid_lifetime, expire, state) \
            values ('3001::3'::inet, 1, 1, 3600, '$future'::timestamp, 1)";
    run_statement "insert 3001::3" "$sql"  "";

    # Insert an expired lease
    sql="insert into lease6 (address, lease_type, subnet_id, valid_lifetime, expire, state) \
            values ('3001::5'::inet, 1, 1, 3600, '$expired'::timestamp, 0)";
    run_statement "insert 3001::5" "$sql"  "";

    # Insert reclaimed lease
    sql="insert into lease6 (address, lease_type, subnet_id, valid_lifetime, expire, state) \
            values ('3001::7'::inet, 1, 1, 3600, '$future'::timestamp, 2)";
    run_statement "insert 3001::7" "$sql"  "";

    sql="select sflqCreateFlqPool6('3001::'::inet, '3001::8'::inet, 1::smallint, 128::smallint,\
                                 1::bigint, false)"
    run_statement "sflqCreateFlqPool6" "$sql"

    sql="select count(address) from lease6 where address in\
         ('3001::1','3001::3','3001::5','3001::7')"
    run_statement "select leases4" "$sql" "4"

    sql="select count(address) from free_lease6 where address in\
         ('3001::','3001::2','3001::4',\
          '3001::6','3001::7','3001::8')"
    run_statement "select free_leases6" "$sql" "6"

    # Let's wipe the whole database
    pgsql_wipe

    test_finish 0
}

# Verifies sflqCreateFlqPool6 parameter validation
pgsql_sflqCreateFlqPool6Invalid() {
    test_start "pgsql.pgsql_sflqCreateFlqPool6Invalid"

    # Let's wipe the whole database
    pgsql_wipe

    # Create the database
    run_command \
        "${kea_admin}" db-init pgsql -u "${db_user}" -p "${db_password}" -n "${db_name}" -d "${db_scripts_dir}"
    assert_eq 0 "${EXIT_CODE}" "cannot initialize the database, expected exit code: %d, actual: %d"

    # Cannot use :: as a start.
    export KEA_EXPECTED_EXIT_CODE="3"
    sql="select sflqCreateFlqPool6('::'::inet, '::1'::inet, 1, 128, 1, false)"
    run_statement "sflqCreateFlqPool6.3" "${sql}"
    unset KEA_EXPECTED_EXIT_CODE

    # Cannot start cannot be greater than end.
    export KEA_EXPECTED_EXIT_CODE="3"
    sql="select sflqCreateFlqPool6('::2'::inet, '::1'::inet, 1, 128, 1, false)"
    run_statement "sflqCreateFlqPool6.3" "${sql}"
    unset KEA_EXPECTED_EXIT_CODE

    # Cannot specify delegated_len < 1
    export KEA_EXPECTED_EXIT_CODE="3"
    sql="select sflqCreateFlqPool6('::1::inet', '::2::inet', 1, 0, 1, false)"
    run_statement "sflqCreateFlqPool6.3" "${sql}"
    unset KEA_EXPECTED_EXIT_CODE

    # Cannot specify delegated_len > 128
    export KEA_EXPECTED_EXIT_CODE="3"
    sql="select sflqCreateFlqPool6('::1'::inet, '::2'::inet, 1, 129, 1, false)"
    run_statement "sflqCreateFlqPool6.3" "${sql}"
    unset KEA_EXPECTED_EXIT_CODE

    # Let's wipe the whole database
    pgsql_wipe

    test_finish 0
}


# Verifies sflqPickFreeLease6 function
pgsql_sflqPickFreeLease6() {
    test_start "pgsql.pgsql_sflqPickFreeLease6"

    # Let's wipe the whole database
    pgsql_wipe

    # Create the database
    run_command \
        "${kea_admin}" db-init pgsql -u "${db_user}" -p "${db_password}" -n "${db_name}" -d "${db_scripts_dir}"
    assert_eq 0 "${EXIT_CODE}" "cannot initialize the database, expected exit code: %d, actual: %d"

    sql="select sflqCreateFlqPool6('3001::'::inet, '3001::02'::inet, 1::smallint,\
                                 128::smallint, 1::bigint, false)"
    run_statement "sflqCreateFlqPool6" "$sql"

    sql="select sflqPickFreeLease6('3001::'::inet, '3001::02'::inet)"
    run_statement "sflqPickFreeLease6.1" "$sql"  "3001::";
    run_statement "sflqPickFreeLease6.2" "$sql"  "3001::1";
    run_statement "sflqPickFreeLease6.3" "$sql"  "3001::2";

    # Inserting a lease directly. Pick should still see it.
    sql="insert into lease6 (address, lease_type, subnet_id) values ('3001::1'::inet, 1::smallint, 1::bigint)";
    run_statement "insert 3001::1" "$sql"  "";

    sql="select sflqPickFreeLease6('3001::'::inet, '3001::02'::inet)"
    run_statement "sflqPickFreeLease6.4" "$sql"  "3001::";
    run_statement "sflqPickFreeLease6.5" "$sql"  "3001::1";
    run_statement "sflqPickFreeLease6.6" "$sql"  "3001::2";

    # Updating to reclaimed directly. Pick should still see it.
    sql="update lease6 set state = 2 where address = ('3001::1'::inet);"
    run_statement "update 3001::1" "$sql"  "";

    sql="select sflqPickFreeLease6('3001::'::inet, '3001::02'::inet)"
    run_statement "sflqPickFreeLease6.7" "$sql"  "3001::";
    run_statement "sflqPickFreeLease6.8" "$sql"  "3001::1";
    run_statement "sflqPickFreeLease6.9" "$sql"  "3001::2";

    # Deleting a lease directly. Pick should still see it.
    sql="delete from lease6"
    run_statement "delete 3001::1" "$sql"  "";

    sql="select sflqPickFreeLease6('3001::'::inet, '3001::02'::inet)"
    run_statement "sflqPickFreeLease6.10" "$sql"  "3001::";
    run_statement "sflqPickFreeLease6.11" "$sql"  "3001::1";
    run_statement "sflqPickFreeLease6.12" "$sql"  "3001::2";

    # Check pools with one address.
    address="'2001:db8::8bd:1002'::inet"
    sql="select sflqCreateFlqPool6(${address}, ${address}, 1::smallint, \
                                 128::smallint, 1::bigint, false)"
    run_statement "sflqCreateFlqPool6.2" "${sql}"

    sql="select sflqPickFreeLease6(${address}, ${address})"
    run_statement "sflqPickFreeLease6.13" "${sql}" "2001:db8::8bd:1002";
    # Rolling over results in the same address when there is only one.
    run_statement "sflqPickFreeLease6.14" "${sql}" "2001:db8::8bd:1002";

    # Check picking last address.
    address="'ffff:ffff:ffff:ffff:ffff:ffff:ffff:ffff'::inet"
    sql="select sflqCreateFlqPool6(${address}, ${address}, 1::smallint, \
                                 128::smallint, 1::bigint, false)"
    run_statement "sflqCreateFlqPool6.3" "${sql}"

    sql="select sflqPickFreeLease6(${address}, ${address})"
    run_statement "sflqPickFreeLease6.17" "${sql}" "ffff:ffff:ffff:ffff:ffff:ffff:ffff:ffff";
    run_statement "sflqPickFreeLease6.18" "${sql}" "ffff:ffff:ffff:ffff:ffff:ffff:ffff:ffff";

    # Let's wipe the whole database
    pgsql_wipe

    test_finish 0
}

# Verifies sflqInsertLease4 function
pgsql_sflqInsertLease4() {
    test_start "pgsql.pgsql_sflqInsertLease4"

    # Let's wipe the whole database
    pgsql_wipe

    # Create the database
    run_command \
        "${kea_admin}" db-init pgsql -u "${db_user}" -p "${db_password}" -n "${db_name}" -d "${db_scripts_dir}"
    assert_eq 0 "${EXIT_CODE}" "cannot initialize the database, expected exit code: %d, actual: %d"

    # Create a SFLQ pool 127.0.0.0 - 127.0.0.4
    start_address="('127.0.0.0'::inet - '0.0.0.0'::inet)"
    end_address="('127.0.0.4'::inet - '0.0.0.0'::inet)"
    sql="select sflqCreateFlqPool4($start_address, $end_address, 1::bigint, false)"
    run_statement "sflqCreateFlqPool4" "$sql"

    # Verify free_lease4 has all five addresses
    sql="select count(address) from free_lease4 \
            where address >= $start_address \
            and address <= $end_address"
    run_statement "check sflqCreateFlqPool4" "$sql" "5"

    # Insert an assigned lease for 127.0.0.1
    lease_address="127.0.0.1"
    bigint_address="('$lease_address'::inet - '0.0.0.0'::inet)"
    sql="select sflqInsertLease4($bigint_address,\
                               NULL, NULL, NULL, NULL,\
                               1::bigint, 'f'::boolean, 'f'::boolean,\
                               NULL, 0::bigint, NULL, NULL, NULL, 0::bigint)"
    run_statement "sflqInsertLease4 $lease_address" "$sql" "1"

    # Verify lease is inserted into lease4 and removed from free_lease4
    sql="select count(address) from lease4 where address = $bigint_address;"
    run_statement "check lease4 1" "$sql" "1"
    sql="select count(address) from free_lease4 where address = $bigint_address;"
    run_statement "check free_lease4 1" "$sql" "0"

    # Insert a declined lease for 127.0.0.2
    lease_address="127.0.0.2"
    bigint_address="('$lease_address'::inet - '0.0.0.0'::inet)"
    sql="select sflqInsertLease4($bigint_address,\
                               NULL, NULL, NULL, NULL,\
                               1::bigint, 'f'::boolean, 'f'::boolean,\
                               NULL, 1::bigint, NULL, NULL, NULL, 0::bigint)"
    run_statement "sflqInsertLease4 $lease_address" "$sql" "1"

    # Verify lease is inserted into lease4 and removed from free_lease4
    sql="select count(address) from lease4 where address = $bigint_address;"
    run_statement "check lease4 2" "$sql" "1"
    sql="select count(address) from free_lease4 where address = $bigint_address;"
    run_statement "check free_lease4 2" "$sql" "0"

    # Insert a reclaimed lease for 127.0.0.3
    lease_address="127.0.0.3"
    bigint_address="('$lease_address'::inet - '0.0.0.0'::inet)"
    sql="select sflqInsertLease4($bigint_address,\
                               NULL, NULL, NULL, NULL,\
                               1::bigint, 'f'::boolean, 'f'::boolean,\
                               NULL, 2::bigint, NULL, NULL, NULL, 0::bigint)"
    run_statement "sflqInsertLease4 $lease_address" "$sql" "1"

    # Verify lease is inserted into lease4 and but not removed from free_lease4
    sql="select count(address) from lease4 where address = $bigint_address;"
    run_statement "check lease4 3" "$sql" "1"
    sql="select count(address) from free_lease4 where address = $bigint_address;"
    run_statement "check free_lease4 3" "$sql"  "1"

    # Insert an expired lease for 127.0.0.4
    lease_address="127.0.0.4"
    bigint_address="('$lease_address'::inet - '0.0.0.0'::inet)"
    sql="select sflqInsertLease4($bigint_address, NULL, NULL,\
                               3600::bigint, (current_timestamp -  make_interval(secs => 10)),\
                               1::bigint, 'f'::boolean, 'f'::boolean,\
                               NULL, 0::bigint, NULL, NULL, NULL, 0::bigint)"
    run_statement "sflqInsertLease4 $lease_address" "$sql" "1"

    # Verify lease is inserted into lease4 and removed from free_lease4
    sql="select count(address) from lease4 where address = $bigint_address;"
    run_statement "check lease4 4" "$sql" "1"
    sql="select count(address) from free_lease4 where address = $bigint_address;"
    run_statement "check free_lease4 4" "$sql"  "0"

    # Let's wipe the whole database
    #pgsql_wipe

    test_finish 0
}

# Verifies sflqUpdateLease4 function
pgsql_sflqUpdateLease4() {
    test_start "pgsql.pgsql_sflqUpdateLease4"

    # Let's wipe the whole database
    pgsql_wipe

    # Create the database
    run_command \
        "${kea_admin}" db-init pgsql -u "${db_user}" -p "${db_password}" -n "${db_name}" -d "${db_scripts_dir}"
    assert_eq 0 "${EXIT_CODE}" "cannot initialize the database, expected exit code: %d, actual: %d"

    # Create a SFLQ pool 127.0.0.0 - 127.0.0.4
    start_address="('127.0.0.0'::inet - '0.0.0.0'::inet)"
    end_address="('127.0.0.4'::inet - '0.0.0.0'::inet)"
    sql="select sflqCreateFlqPool4($start_address, $end_address, 1::bigint, false)"
    run_statement "sflqCreateFlqPool4" "$sql"

    # Verify free_lease4 has all five addresses
    sql="select count(address) from free_lease4 \
            where address >= $start_address \
            and address <= $end_address"
    run_statement "check sflqCreateFlqPool4" "$sql" "5"

    # Get a future timestamp
    sql="select (current_timestamp + make_interval(secs => 3600))"
    run_statement "get future time stamp" "$sql"
    future="${OUTPUT}"

    # Insert an assigned lease for 127.0.0.1
    lease_address="127.0.0.1"
    bigint_address="('$lease_address'::inet - '0.0.0.0'::inet)"
    sql="select sflqInsertLease4($bigint_address, NULL, NULL, 3600::bigint, '$future'::timestamp,\
                               1::bigint, 'f'::boolean, 'f'::boolean, NULL, \
                               0::bigint, NULL, NULL, NULL, 0::bigint)";
    run_statement "sflqInsertLease4 $lease_address" "$sql" "1"

    # Verify lease is inserted into lease4 and removed from free_lease4
    sql="select count(address) from lease4 where address = $bigint_address;"
    run_statement "check lease4 1" "$sql" "1"
    sql="select count(address) from free_lease4 where address = $bigint_address;"
    run_statement "check free_lease4 1" "$sql" "0"

    # Update the lease to declined
    sql="select sflqUpdateLease4($bigint_address, NULL, NULL, 3600::bigint, '$future'::timestamp,\
                               1::bigint, 'f'::boolean, 'f'::boolean, NULL,\
                               1::bigint, NULL, NULL, NULL, 0::bigint,\
                               $bigint_address, '$future'::timestamp)";
    run_statement "sflqUpdateLease4 1" "$sql" "1"

    # Verify lease is updated lease4 and but not present free_lease4
    sql="select count(address) from lease4 where address = $bigint_address and state = 1;"
    run_statement "check lease4 2" "$sql" "1"
    sql="select count(address) from free_lease4 where address = $bigint_address;"
    run_statement "check free_lease4 2" "$sql" "0"

    # Update the lease to be reclaimed.
    sql="select sflqUpdateLease4($bigint_address, NULL, NULL, 3600::bigint, '$future'::timestamp,\
                               1::bigint, 'f'::boolean, 'f'::boolean, NULL,\
                               2::bigint, NULL, NULL, NULL, 0::bigint,\
                               $bigint_address, '$future'::timestamp)";
    run_statement "sflqUpdateLease4 2" "$sql" "1"

    # Verify lease is updated in lease4 and added to free_lease4
    sql="select count(address) from lease4 where address = $bigint_address and state = 2;"
    run_statement "check lease4 3" "$sql" "1"
    sql="select count(address) from free_lease4 where address = $bigint_address;"
    run_statement "check free_lease4 3" "$sql"  "1"

    # Update requires expirations to match. In order to test expiration
    # logic, need to get an expired time stamp and then update the lease
    # directly setting expire.
    sql="select (current_timestamp - make_interval(secs => 3600))"
    run_statement "get expired time stamp" "$sql"
    expired="${OUTPUT}"
    sql="update lease4 set expire = '$expired'::timestamp\
         where address = $bigint_address"
    run_statement "update lease with expired time stamp" "$sql"

    # Delete the lease from free_lease4;
    sql="delete from free_lease4 where address = $bigint_address;"
    run_statement "manually delete lease" "$sql"

    # Update the expired lease.
    sql="select sflqUpdateLease4($bigint_address, NULL, NULL, 3600::bigint, '$expired'::timestamp,\
                               1::bigint, 'f'::boolean, 'f'::boolean, NULL,\
                               0::bigint, NULL, NULL, NULL, 0::bigint,\
                               $bigint_address, '$expired'::timestamp)";
    run_statement "sflqUpdateLease4 3" "$sql" "1"

    # Verify lease is updated in lease4 but not added to free_lease4
    sql="select count(address) from lease4 where address = $bigint_address and state = 0;"
    run_statement "check lease4 4" "$sql" "1"
    sql="select count(address) from free_lease4 where address = $bigint_address;"
    run_statement "check free_lease4 4" "$sql"  "0"

    # Let's wipe the whole database
#    pgsql_wipe

    test_finish 0
}

pgsql_sflqDeleteLease4() {
    test_start "pgsql.pgsql_sflqDeleteLease4"

    # Let's wipe the whole database
    pgsql_wipe

    # Create the database
    run_command \
        "${kea_admin}" db-init pgsql -u "${db_user}" -p "${db_password}" -n "${db_name}" -d "${db_scripts_dir}"
    assert_eq 0 "${EXIT_CODE}" "cannot initialize the database, expected exit code: %d, actual: %d"

    # Create a SFLQ pool 127.0.0.0 - 127.0.0.4
    start_address="('127.0.0.0'::inet - '0.0.0.0'::inet)"
    end_address="('127.0.0.4'::inet - '0.0.0.0'::inet)"
    sql="select sflqCreateFlqPool4($start_address, $end_address, 1::bigint, false)"
    run_statement "sflqCreateFlqPool4" "$sql"

    # Verify free_lease4 has all five addresses
    sql="select count(address) from free_lease4 \
            where address >= $start_address \
            and address <= $end_address"
    run_statement "check sflqCreateFlqPool4" "$sql" "5"

    # Get a future timestamp
    sql="select (current_timestamp + make_interval(secs => 3600))"
    run_statement "get future time stamp" "$sql"
    future="${OUTPUT}"


    # Insert an assigned lease for 127.0.0.1
    lease_address="127.0.0.1"
    bigint_address="('$lease_address'::inet - '0.0.0.0'::inet)"
    sql="select sflqInsertLease4($bigint_address, NULL, NULL, 3600::bigint, '$future'::timestamp,\
                               1::bigint, 'f'::boolean, 'f'::boolean, NULL, \
                               0::bigint, NULL, NULL, NULL, 0::bigint)";
    run_statement "sflqInsertLease4 $lease_address" "$sql" "1"

    # Verify lease is inserted into lease4 and removed from free_lease4
    sql="select count(address) from lease4 where address = $bigint_address;"
    run_statement "check lease4 1" "$sql" "1"
    sql="select count(address) from free_lease4 where address = $bigint_address;"
    run_statement "check free_lease4 1" "$sql" "0"

    # Attempt to delete lease with mismatched expire.
    sql="select sflqDeleteLease4($bigint_address, current_timestamp)"
    run_statement "sflqDeleteLease4 $bigint_address" "$sql" "0"

    # Verify lease is still in lease4 and not in free_lease4
    sql="select count(address) from lease4 where address = $bigint_address;"
    run_statement "check lease4 2" "$sql" "1"
    sql="select count(address) from free_lease4 where address = $bigint_address;"
    run_statement "check free_lease4 2" "$sql" "0"

    # Delete lease with matching expire.
    sql="select sflqDeleteLease4($bigint_address, '$future'::timestamp)"
    run_statement "sflqDeleteLease4 $bigint_address" "$sql" "1"

    # Verify lease is not in lease4 but is in free_lease4
    sql="select count(address) from lease4 where address = $bigint_address;"
    run_statement "check lease4 3" "$sql" "0"
    sql="select count(address) from free_lease4 where address = $bigint_address;"
    run_statement "check free_lease4 3" "$sql" "1"

    # Let's wipe the whole database
    pgsql_wipe

    test_finish 0
}

pgsql_sflqInsertLease6() {
    test_start "pgsql.pgsql_sflqInsertLease6"

    # Let's wipe the whole database
    pgsql_wipe

    # Create the database
    run_command \
        "${kea_admin}" db-init pgsql -u "${db_user}" -p "${db_password}" -n "${db_name}" -d "${db_scripts_dir}"
    assert_eq 0 "${EXIT_CODE}" "cannot initialize the database, expected exit code: %d, actual: %d"

    # Create a SFLQ pool 3001:: - 3001::4
    sql="select sflqCreateFlqPool6('3001::'::inet, '3001::4'::inet, 1::smallint, 128::smallint,\
                                 1::bigint, false)"
    run_statement "sflqCreateFlqPool6" "$sql"

    # Verify free_lease6 has all five addresses
    sql="select count(bin_address) from free_lease6 \
            where bin_address >= inetToBytea('3001::'::inet) \
            and bin_address <= inetToBytea('3001::4'::inet)"
    run_statement "check sflqCreateFlqPool6" "$sql" "5"

    # Get a future timestamp
    sql="select (CURRENT_TIMESTAMP + make_interval(secs => 3600))"
    run_statement "get expired time stamp" "$sql"
    future="${OUTPUT}"

    # Get an expired timestamp
    sql="select (CURRENT_TIMESTAMP - make_interval(secs => 3600))"
    run_statement "get expired time stamp" "$sql"
    expired="${OUTPUT}"

    # Insert an assigned lease for 3001::1
    in_address="'3001::1'"
    bin_address="inetToBytea('3001::1'::inet)"
    duid="decode('01020304','hex')"
    subnet_id="1"
    ltype="1"
    iaid="1234"
    state="0"
    sql="select sflqInsertLease6($in_address::inet, $duid, 3600::bigint, '$future'::timestamp,\
                               $subnet_id::bigint, 3600::bigint, $ltype::smallint, \
                               $iaid::integer, 128::smallint, 'f'::boolean, 'f'::boolean,\
                               NULL, NULL, 0::smallint, 0::smallint, $state::bigint, \
                               NULL, 0::bigint)"
    run_statement "sflqInsertLease6 $in_address" "$sql" "1"

    # Verify lease is inserted into lease6 and removed from free_lease6
    sql="select count(address) from lease6 where address = $in_address::inet;"
    run_statement "check lease6 1" "$sql" "1"
    sql="select count(address) from free_lease6 where bin_address = $bin_address;"
    run_statement "check free_lease6 1" "$sql" "0"

    # Insert a declined lease for 3001::2
    in_address="'3001::2'"
    bin_address="inetToBytea('3001::2'::inet)"
    state="1"
    sql="select sflqInsertLease6($in_address::inet, $duid, 3600::bigint, '$future'::timestamp,\
                               $subnet_id::bigint, 3600::bigint, $ltype::smallint, \
                               $iaid::integer, 128::smallint, 'f'::boolean, 'f'::boolean,\
                               NULL, NULL, 0::smallint, 0::smallint, $state::bigint, \
                               NULL, 0::bigint)"
    run_statement "sflqInsertLease6 $in_address" "$sql" "1"

    # Verify lease is inserted into lease6 and removed from free_lease6
    sql="select count(address) from lease6 where address = $in_address::inet;"
    run_statement "check lease6 2" "$sql" "1"
    sql="select count(address) from free_lease6 where bin_address = $bin_address;"
    run_statement "check free_lease6 2" "$sql" "0"

    # Insert a reclaimed lease for 3001::3
    in_address="'3001::3'"
    bin_address="inetToBytea('3001::3'::inet)"
    state="2"
    sql="select sflqInsertLease6($in_address::inet, $duid, 3600::bigint, '$future'::timestamp,\
                               $subnet_id::bigint, 3600::bigint, $ltype::smallint, \
                               $iaid::integer, 128::smallint, 'f'::boolean, 'f'::boolean,\
                               NULL, NULL, 0::smallint, 0::smallint, $state::bigint, \
                               NULL, 0::bigint)"
    run_statement "sflqInsertLease6 $in_address" "$sql" "1"

    # Verify lease is inserted into lease6 and but not removed from free_lease6
    sql="select count(address) from lease6 where address = $in_address::inet;"
    run_statement "check lease6 3" "$sql" "1"
    sql="select count(address) from free_lease6 where bin_address = $bin_address;"
    run_statement "check free_lease6 3" "$sql" "1"

    # Insert an expired lease for 3001::4
    in_address="'3001::4'"
    bin_address="inetToBytea('3001::4'::inet)"
    state="0"
    sql="select sflqInsertLease6($in_address::inet, $duid, 3600::bigint, '$expired'::timestamp,\
                               $subnet_id::bigint, 3600::bigint, $ltype::smallint, \
                               $iaid::integer, 128::smallint, 'f'::boolean, 'f'::boolean,\
                               NULL, NULL, 0::smallint, 0::smallint, $state::bigint, \
                               NULL, 0::bigint)"
    run_statement "sflqInsertLease6 $in_address" "$sql" "1"

    # Verify lease is inserted into lease6 and removed from free_lease6
    sql="select count(address) from lease6 where address = $in_address::inet;"
    run_statement "check lease6 4" "$sql" "1"
    sql="select count(address) from free_lease6 where bin_address = $bin_address;"
    run_statement "check free_lease6 4" "$sql" "0"

    # Let's wipe the whole database
    pgsql_wipe

    test_finish 0
}

