    run_statement "sflqUpdateLease6 $in_address" "$sql" "1"

    # Verify lease is updated in lease6 and added to free_lease6
    sql="select count(address) from lease6 where address = $in_address::inet and state = 2;"
    run_statement "check lease6 3" "$sql" "1"
    sql="select count(address) from free_lease6 where bin_address = $bin_address;"
    run_statement "check free_le3se6 3" "$sql" "1"

    # Update requires expirations to match. In order to test expiration
    # logic, need to update the lease directly setting expire.
    sql="update lease6 set expire = '$expired'::timestamp\
         where address = $in_address"
    run_statement "update lease with expired time stamp" "$sql"

    # Manually delete the lease from free_lease6;
    sql="delete from free_lease6 where bin_address = $bin_address;"
    run_statement "manually delete lease" "$sql"

    # Update the expired lease.
    state=0
    sql="select sflqUpdateLease6($in_address::inet, $duid, 3600::bigint, '$expired'::timestamp,\
                               $subnet_id::bigint, 3600::bigint, $ltype::smallint, \
