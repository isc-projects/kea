    "hook": "lease_cmds",
    "name": "sflq-pool4-get-all",
    "resp-syntax": [
        "{",
        "\"arguments\": {",
        "   \"pools\": [",
        "       {",
        "            \"created-ts\": \"2026-05-02 10:54:55.000000\",",
        "            \"delegated-len\": 128,",
        "            \"end-address\": \"192.0.2.255\",",
        "            \"free-leases\": 256,",
        "            \"lease-type\": \"V4\",",
        "            \"modified-ts\": \"2026-05-02 10:54:55.000000\",",
        "            \"start-address\": \"192.0.2.0\",",
        "            \"subnet-id\": 6",
        "       }",
