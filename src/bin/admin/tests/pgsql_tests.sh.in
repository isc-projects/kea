    run_statement "sflqUpdateLease6 $in_address" "$sql" "1"

    # Verify lease is updated in lease6 but not added to free_lease6
    sql="select count(address) from lease6 where address = $in_address::inet and state = 0;"
    run_statement "check lease6 4" "$sql" "1"
    sql="select count(address) from free_lease6 where bin_address = $bin_address;"
    run_statement "check free_lease6 4" "$sql" "0"

    # Let's wipe the whole database
    pgsql_wipe

    test_finish 0
}

